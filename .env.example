# FastAPI application
APP_NAME=东软智慧商务 AI 助手平台
APP_ENV=development
API_V1_PREFIX=/api/v1
DEBUG=false

# Host ports shared by Docker and native development
APP_BACKEND_PORT=18000
APP_FRONTEND_PORT=5173

# Business PostgreSQL, Redis and authentication
APP_POSTGRES_DB=smart_business_ai
APP_POSTGRES_USER=smart_business_ai
APP_POSTGRES_PASSWORD=replace-me
APP_POSTGRES_PORT=15432
APP_REDIS_PASSWORD=replace-me
APP_REDIS_PORT=16379
DATABASE_URL=postgresql+psycopg://smart_business_ai:replace-me@127.0.0.1:15432/smart_business_ai
REDIS_URL=redis://:replace-me@127.0.0.1:16379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret
DEMO_PASSWORD=replace-with-at-least-8-characters

# AI services
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DASHSCOPE_API_KEY=
BAILIAN_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
BAILIAN_WORKSPACE_ID=
DIFY_BASE_URL=http://localhost:18080/v1
DIFY_CHAT_APP_API_KEY=
DIFY_WORKFLOW_API_KEY=
DIFY_DATASET_API_KEY=
DIFY_DATASET_ID=
DIFY_TTS_TIMEOUT_SECONDS=120
DIFY_TTS_MAX_RESPONSE_BYTES=5242880

# Knowledge document storage
KNOWLEDGE_UPLOAD_DIR=backend/.data/knowledge_documents
KNOWLEDGE_MAX_UPLOAD_BYTES=15728640
